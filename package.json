{
  "name": "floridanomics-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "data:refresh": "tsx scripts/refresh-data.ts",
    "data:validate": "tsx scripts/validate-data.ts",
    "dev:dashboard": "npm run data:refresh && npm run dev",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:audit": "npm audit --audit-level=high",
    "security:prod": "npm audit --omit=dev --audit-level=moderate",
    "qa:full": "npm run data:refresh && npm run data:validate && npm run lint && npm run build && npm run security:audit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
